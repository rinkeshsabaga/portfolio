  });


  function tab_value_change(tab_val){
        
        if(tab_val=='1'){
          $('#achievement_title').text('Faculty Achievements');
		  
          $('.achieve_img_set_1').removeClass('no-display');
          $('.achieve_img_set_1').addClass('display-true');
          $('.achieve_img_set_2').addClass('no-display');
          $('.achieve_img_set_2').removeClass('display-true');         
          $('.achieve_img_set_3').addClass('no-display');
          $('.achieve_img_set_3').removeClass('display-true');
        }
        if(tab_val=='2'){ 
          $('#achievement_title').text('Student Achievements');
		  
          $('.achieve_img_set_1').addClass('no-display');
          $('.achieve_img_set_1').removeClass('display-true');
          $('.achieve_img_set_2').removeClass('no-display'); 
          $('.achieve_img_set_2').addClass('display-true');       
          $('.achieve_img_set_3').addClass('no-display');
          $('.achieve_img_set_3').removeClass('display-true');
        }
        if(tab_val=='3'){
          $('#achievement_title').text('University Achievements');
			
          $('.achieve_img_set_1').addClass('no-display');
          $('.achieve_img_set_1').removeClass('display-true');
          $('.achieve_img_set_2').addClass('no-display');
          $('.achieve_img_set_2').removeClass('display-true');        
          $('.achieve_img_set_3').removeClass('no-display');
          $('.achieve_img_set_3').addClass('display-true');          
        }
          
  }
  tab_value_change(1);

</script>

<script>
    const sliderEl = document.querySelector('#smartSlider');
    const carousel = new bootstrap.Carousel(sliderEl, { interval: false });
    const video = document.querySelector('#heroVideo');
    let timer;

    function handleSlideTiming(index) {
        clearTimeout(timer);
        const slides = document.querySelectorAll('.carousel-item');
        const activeSlide = slides[index];
        
        // Ensure video is paused if we leave the video slide
        if (activeSlide.id !== 'videoSlide') {
            video.pause();
        }

        // 1. Logic for Video Slide
        if (activeSlide.id === 'videoSlide') {
            video.currentTime = 0;
            video.play().catch(e => console.log("Autoplay blocked. User interaction required."));
            
            // Wait for video to end before sliding
            video.onended = () => carousel.next();
        } 
        // 2. Logic for Image Slides
        else {
            const duration = activeSlide.getAttribute('data-duration') || 5000;
            timer = setTimeout(() => {
                carousel.next();
            }, duration);
        }
    }

    // Event listener for slide transition
    sliderEl.addEventListener('slid.bs.carousel', event => {
        handleSlideTiming(event.to);
    });

    // Run on page load for the first slide
    window.onload = () => handleSlideTiming(0);
</script>


