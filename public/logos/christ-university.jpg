                <div class="hero-section shadow-sm" id="main-hero">
				                     <span class="category-pill" id="hero-cat">  </span>
                    <h1 class="hero-title" id="hero-title"> World University Rankings for Innovation (WURI) 2026</h1>
                   <p class="text-muted mb-4 lead" id="hero-desc"></p>
                 <a href="https://christuniversity.in/news/V29ybGQgVW5pdmVyc2l0eSBSYW5raW5ncyBmb3IgSW5ub3ZhdGlvbiAoV1VSSSkgMjAyNg==" class="btn btn-campus" id="hero-link">
    Read Full Story
				 </a>                </div>
            </div>

            <div class="col-lg-5">
            <div class="rgt-wdth-itm">
		                <div class="side-news-item active" data-index="0">
                    <div class="meta-text">Dec 31 2026</div>
                    <div class="item-title">World University Rankings for Innovation (WURI) 2026</div>
                </div>
		                  <div class="side-news-item " data-index="1">
                    <div class="meta-text">Mar 31 2027</div>
                    <div class="item-title">India Today-MDRA Best Colleges Ranking 2026</div>
                </div>
		               
                
                </div>
            </div>
        </div>
    </div>
</section>


<script>
document.addEventListener('DOMContentLoaded', () => {
     // 1. Data Source (FIXED)
    const newsData = [
                {
            category: "General",
            title: "World University Rankings for Innovation (WURI) 2026",
            description: "",
            link: "https://christuniversity.in/news/V29ybGQgVW5pdmVyc2l0eSBSYW5raW5ncyBmb3IgSW5ub3ZhdGlvbiAoV1VSSSkgMjAyNg=="
        },
                {
            category: "General",
            title: "India Today-MDRA Best Colleges Ranking 2026",
            description: "",
            link: "https://christuniversity.in/news/SW5kaWEgVG9kYXktTURSQSBCZXN0IENvbGxlZ2VzIFJhbmtpbmcgMjAyNg=="
        },
            ];
    let currentIndex = 0;
    const sidebarItems = document.querySelectorAll('.side-news-item');
    const heroContainer = document.getElementById('main-hero');
    const hCat = document.getElementById('hero-cat');
    const hTitle = document.getElementById('hero-title');
    const hDesc = document.getElementById('hero-desc');
    const hLink = document.getElementById('hero-link'); 
    let autoRotateInterval;

    // 2. Update Function
function updateContent(index) {
    heroContainer.style.opacity = '0';

    setTimeout(() => {
        const data = newsData[index];

        hCat.textContent = data.category;
        hTitle.textContent = data.title;
        hDesc.textContent = data.description;
        hLink.href = data.link; // ✅ THIS WAS MISSING

        sidebarItems.forEach(item => item.classList.remove('active'));

        if(sidebarItems[index]){
            sidebarItems[index].classList.add('active');
        }

        heroContainer.style.opacity = '1';
        currentIndex = index;
    }, 400);
}

    // 3. Click Events
    sidebarItems.forEach((item, index) => {
        item.addEventListener('click', () => {
            if(currentIndex === index) return; // Do nothing if clicking already active item
            updateContent(index);
            resetTimer();
        });
    });

    // 4. Timer Logic
    function startTimer() {
        autoRotateInterval = setInterval(() => {
            let nextIndex = (currentIndex + 1) % newsData.length;
            updateContent(nextIndex);
        }, 5000); // 5 seconds
    }

    function resetTimer() {
        clearInterval(autoRotateInterval);
        startTimer();
    }

    // Initialize
    startTimer();
});
</script>



