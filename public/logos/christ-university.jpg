<section id="admissn-on-home" class="admissions-section py-5 reveal visible">
  <div class="container-xl py-4 position-relative" style="z-index:2;">
    <div class="row g-5 align-items-center">
      <div class="col-lg-6">
        <div class="section-label" style="color:var(--cu-gold-lt);">Admissions 2026-27</div>
        <h2 class="section-title text-white mt-1">Where Your
<br>
          <em>Christ Story Begins</em></h2>
        <p class="mt-3 mb-4" style="color:rgba(255,255,255,.6);font-size:.97rem;line-height:1.75;">Applications are open for all UG, PG and Doctoral programmes. Join a community dedicated to excellence, service and lifelong growth.</p>
        <div class="d-flex gap-3 flex-wrap"><a href="https://espro.christuniversity.in/Application/" target="_blank" rel="noopener noreferrer" class="btn btn-cu-white px-4 py-2 rounded-3">Apply Online</a><a href="#" class="btn btn-cu-ghost px-4 py-2 rounded-3">Download Brochure</a></div>
      </div>
      <div class="col-lg-6">
        <div class="adm-steps-card">
          <h4 class="font-serif text-white mb-4 pb-3" style="border-bottom:1px solid rgba(255,255,255,.1);font-size:1.3rem;">How to Apply</h4>
          <div class="d-flex flex-column gap-3">
            <div class="d-flex gap-3 align-items-start">
              <div class="step-num">1</div>
              <div>
                <div class="adm-step-title">Register Online</div>
                <div class="adm-step-sub">Create your profile on the Christ admissions portal</div>
              </div>
            </div>
            <div class="d-flex gap-3 align-items-start">
              <div class="step-num">2</div>
              <div>
                <div class="adm-step-title">Select Programme</div>
                <div class="adm-step-sub">Choose your preferred school and programme</div>
              </div>
            </div>
            <div class="d-flex gap-3 align-items-start">
              <div class="step-num">3</div>
              <div>
                <div class="adm-step-title">Submit Documents</div>
                <div class="adm-step-sub">Upload academic records and complete the form</div>
              </div>
            </div>
            <div class="d-flex gap-3 align-items-start">
              <div class="step-num">4</div>
              <div>
                <div class="adm-step-title">Selection Process</div>
                <div class="adm-step-sub">Written test, group discussion or interview</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>



